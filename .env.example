PORT=3000
JWT_SECRET=replace_with_a_strong_secret
ADMIN_KEY=optional_admin_key_for_lab_user_management
DATABASE_URL=postgresql://user:password@host:5432/database

# Staff account for /lab/ (created automatically on first boot if email not taken)
LAB_STAFF_EMAIL=you@example.com
LAB_STAFF_PASSWORD=change_me_strong_password
LAB_STAFF_NAME=Lab Admin

# Optional: same app, different hostnames → redirect / to /store/ or /lab/
# STORE_HOST=shop.example.com
# LAB_HOST=lab.example.com

# Outbound webhooks (POST JSON after DB commit; failures are logged only)
# N8N_ORDER_WEBHOOK_URL=https://your-n8n/webhook/order
# N8N_LEAD_WEBHOOK_URL=https://your-n8n/webhook/lead
# N8N_BOOKING_WEBHOOK_URL=https://your-n8n/webhook/booking
# N8N_WEBHOOK_SECRET=shared_secret_for_X_Lab_Signature_header

# Shared rate limit for POST /api/store/leads and POST /api/store/bookings (per IP)
# STORE_PUBLIC_RATE_MAX=40
# STORE_PUBLIC_RATE_WINDOW_MS=900000
